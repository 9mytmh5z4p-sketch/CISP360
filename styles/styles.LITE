/*
  p360 Lecture Styles
  version: 02.00.00
  Changelog:
  02.00.00 (2026-03-15) - Rebuilt from defaults. Removed positional hacks,
                          header underlines, nowrap, and 98vh code blocks.
                          Kept: background image, logo, code highlight colors,
                          overview styles, utility classes.
  01.00.00 (2026-02-03) - Initial version.
*/


/* ===== Theme token overrides ===================================
   Override the Quarto serif theme via its own CSS custom properties.
   No !important needed — these beat the theme at the cascade root.
   ============================================================= */
:root {
  --r-main-font-size: 36px;
  --r-background-color: #f0f1eb;
}


/* ===== Background image (viewport, behind slide boxes) ========= */
.reveal {
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0.55)),
    url('../img/tech_background.jpg');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  /* scroll, not fixed — fixed backgrounds drop out in PDF export */
  background-attachment: scroll;
}


/* ===== Logo — bottom-left of viewport ========================== */
.reveal::before {
  content: '';
  position: fixed;
  bottom: 15px;
  left: 40px;
  width: 70px;
  height: 70px;
  background: url('../img/stacked-logo.svg') no-repeat center;
  background-size: contain;
  z-index: 1000;
  pointer-events: none;
}


/* ===== Slide box ===============================================
   88% width centers neatly; let Reveal.js own vertical placement.
   ============================================================= */
.reveal .slides section {
  width: 88%;
  margin: 0 auto;
  padding: 0.75em 2.25em;
  box-sizing: border-box;
  background-color: rgba(255, 255, 255, 0.96);
  background-image: none;
  font-size: clamp(0.75em, 1.8vw, 1em);
}


/* ===== Code blocks ============================================= */

/* Cap height so a long block can't swallow the whole slide */
.reveal pre {
  max-height: 55vh;
  overflow-y: auto;
}

.reveal pre code {
  font-size: 0.9em;
  line-height: 1.25;
  padding: 0.6em;
}

/* C++ blocks: white background for contrast against parchment theme */
.reveal pre.sourceCode.cpp,
.reveal pre.sourceCode.cpp code {
  background-color: #ffffff;
  color: #000000;
}

.reveal pre.sourceCode.cpp {
  border: 1px solid #d0d0d0;
}


/* ===== Code line highlighting ================================== */

/* Kept from v1 — warm amber palette is well-chosen */
.reveal pre .line-highlight {
  background-color: #fff3cd;
  display: block;
  width: 100%;
}

.reveal pre .line-highlight .hljs-ln-numbers {
  font-weight: bold;
  color: #b45309;
}

.reveal .highlight-line {
  background-color: rgba(255, 235, 59, 0.12);
  border-left: 5px solid #d97706;
  padding-left: 0.5em;
}


/* ===== Overview mode =========================================== */
.reveal.overview {
  background-color: #1a1a1a;
}

.reveal.overview .slides section {
  background-color: #f5f5f5;
  border: 2px solid #888;
  opacity: 0.85;
}

.reveal.overview .slides section:hover {
  opacity: 1;
  border-color: #e07b54;
  transform: scale(1.04);
}

.reveal.overview .slides section.present {
  border: 3px solid #4ecdc4;
  opacity: 1;
}


/* ===== Utility classes ========================================= */

.smaller-table table {
  font-size: 0.72em;
  width: 90%;
  margin: 0 auto;
}

.smallest-table table {
  font-size: 0.55em;
  width: 60%;
  margin: 0 auto;
}

.smaller-text {
  font-size: 0.75em;
}

.smallest-text {
  font-size: 0.55em;
}
